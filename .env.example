# App
NEXT_PUBLIC_APP_URL=http://localhost:3000

# Demo mode — bypasses Stripe checkout, creates projects as active immediately.
# MUST NOT be "true" in production (isDemoMode() guard blocks it anyway).
DEMO_MODE=false

# Clerk Auth
NEXT_PUBLIC_CLERK_PUBLISHABLE_KEY=pk_test_PLACEHOLDER
CLERK_SECRET_KEY=sk_test_PLACEHOLDER
CLERK_WEBHOOK_SECRET=whsec_PLACEHOLDER

# Database (Supabase PostgreSQL)
DATABASE_URL=postgresql://postgres:password@localhost:5432/sitefile

# Cloudflare R2 Storage
R2_ACCOUNT_ID=PLACEHOLDER
R2_ACCESS_KEY_ID=PLACEHOLDER
R2_SECRET_ACCESS_KEY=PLACEHOLDER
R2_BUCKET_NAME=sitefile-media
R2_PUBLIC_URL=https://media.sitefile.app

# Claude AI
ANTHROPIC_API_KEY=sk-ant-PLACEHOLDER

# Inngest
INNGEST_EVENT_KEY=PLACEHOLDER
INNGEST_SIGNING_KEY=PLACEHOLDER

# Stripe
STRIPE_SECRET_KEY=sk_test_PLACEHOLDER
STRIPE_WEBHOOK_SECRET=whsec_PLACEHOLDER
NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY=pk_test_PLACEHOLDER
STRIPE_PRICE_ID=price_PLACEHOLDER

# Mapbox
NEXT_PUBLIC_MAPBOX_TOKEN=pk.PLACEHOLDER
